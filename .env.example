# ── Core ──────────────────────────────────────────────
FLASK_APP=flask_cli.py
SECRET_KEY=change-me-to-a-random-32-char-string
DATABASE_URL=postgresql://adm_terminchen:change_me@db:5432/pg_terminchen
BASE_URL=http://localhost:5000

# ── Calendar Defaults ──────────────────────────────────
DEFAULT_TIMEZONE=Europe/Vienna
DEFAULT_VIEW=month
DEFAULT_WEEK_START=0

# ── Upload ─────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=2
UPLOAD_DIR=/app/uploads

# ── Security ───────────────────────────────────────────
SECURE_COOKIES=false
SESSION_LIFETIME_HOURS=720
ADMIN_SESSION_LIFETIME_HOURS=24

# ── Integration ────────────────────────────────────────
CORS_ALLOWED_ORIGINS=
EMBED_ALLOWED_ORIGINS=

# ── Appearance ─────────────────────────────────────────
APP_NAME=terminchen
APP_TAGLINE=Create a shared calendar in seconds. No accounts needed.
GITHUB_URL=
SEO_DOMAIN=

# ── Analytics (optional — leave empty to disable) ─────
CLOUDFLARE_BEACON_TOKEN=

# ── Email / SMTP (optional — leave SMTP_HOST empty to disable) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=terminchen

# ── Legal / Impressum (optional — shown when any value is set) ──
LEGAL_NAME=
LEGAL_ADDRESS=
LEGAL_EMAIL=
LEGAL_PHONE=
LEGAL_EXTRA=

# ── Social / Support Links (optional — shown on Impressum page) ──
# Leave empty to hide. Only links with a URL will be displayed.
SOCIAL_MASTODON=
SOCIAL_BLUESKY=
SOCIAL_X=
SOCIAL_PATREON=
SOCIAL_KOFI=
SOCIAL_BUYMEACOFFEE=
SOCIAL_GITHUB=
SOCIAL_WEBSITE=

# ── Logging ────────────────────────────────────────────
LOG_LEVEL=INFO
TZ=UTC

# ── Docker / PostgreSQL ────────────────────────────────
DOCKER_USER=1000
DOCKER_GROUP=1000
POSTGRES_USER=adm_terminchen
POSTGRES_PASSWORD=change_me
POSTGRES_DB=pg_terminchen
